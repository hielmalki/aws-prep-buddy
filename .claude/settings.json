{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/block-generated.js",
            "statusMessage": "Checking file path..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/block-generated-bash.js && node .claude/hooks/suggest-excludes.js",
            "statusMessage": "Checking command..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/truncate-long-output.js",
            "statusMessage": "Checking output size..."
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/session-brief.js",
            "statusMessage": "Loading session brief..."
          }
        ]
      }
    ]
  }
}
